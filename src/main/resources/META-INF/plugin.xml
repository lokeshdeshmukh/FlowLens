<idea-plugin>
    <id>com.flowlens.plugin</id>
    <name>FlowLens</name>
    <vendor email="support@flowlens.dev" url="https://flowlens.dev">FlowLens</vendor>

    <description><![CDATA[
    <p>Analyze Android navigation and visualize app screen flows inside Android Studio.</p>
    <ul>
        <li>Scans Navigation Component XML, Compose navigation, and explicit Activity launches</li>
        <li>Builds an interactive graph with search, zoom, pan, and export support</li>
        <li>Shows navigation details, deep links, ViewModels, and repository references per screen</li>
    </ul>
    ]]></description>

    <change-notes><![CDATA[
    <p>Initial FlowLens release.</p>
    ]]></change-notes>

    <version>0.1.0</version>
    <idea-version since-build="253"/>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>
    <depends>com.intellij.modules.androidstudio</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow
                id="Flow Graph"
                anchor="right"
                icon="/icons/flowlensToolWindow.svg"
                factoryClass="com.flowlens.toolwindow.FlowGraphToolWindowFactory"
                canCloseContent="false"/>
    </extensions>

    <actions>
        <action
                id="FlowLens.AnalyzeAppFlow"
                class="com.flowlens.actions.AnalyzeAppFlowAction"
                text="Analyze App Flow"
                description="Analyze the current Android project and open the Flow Graph tool window"
                icon="/icons/flowlensAction.svg">
            <add-to-group group-id="MainToolbarRight" anchor="last"/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>

